# Backend Configuration

# Database URL
# For SQLite (development): sqlite:///./uat_tool.db
# For PostgreSQL: postgresql://user:password@localhost:5432/uat_tool
DATABASE_URL=sqlite:///./uat_tool.db

# Upload settings
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE=104857600  # 100 MB in bytes

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Email settings (for issue notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@uat-tool.com

# Frontend Configuration (in .env or .env.local)

# API URL - Backend endpoint
REACT_APP_API_URL=http://localhost:8000/api

# Demo mode - Show sample data on startup
REACT_APP_DEMO_MODE=false
